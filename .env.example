# ──────────────────────────────────────────────────────────────────────────────
# OneShot Cloud Sync – environment variables
#
# Copy this file to .env.local and fill in the values for your chosen mode.
# .env.local is git-ignored and is never committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Active sync mode ──────────────────────────────────────────────────────────
# Options: relay | database
SYNC_MODE=relay

# ══════════════════════════════════════════════════════════════════════════════
# MODE: relay  (Ably WebSocket pub/sub – ephemeral, zero DB setup)
# ══════════════════════════════════════════════════════════════════════════════
# 1. Create a free account at https://ably.com
# 2. Create an app and copy the Root API Key (for the local watcher)
# 3. Optionally create a second key with limited capabilities for the frontend
#    (subscribe + publish on "oneshot-canvas" channel only)

# Local watcher (secret – only in .env.local, never commit)
ABLY_API_KEY=your-root-ably-api-key
ABLY_CHANNEL=oneshot-canvas          # optional, default: oneshot-canvas

# Frontend / Vercel build-time variables (safe to set in Vercel dashboard)
VITE_APP_SYNC_MODE=relay
VITE_APP_ABLY_API_KEY=your-ably-api-key   # use a client-restricted key here
VITE_APP_ABLY_CHANNEL=oneshot-canvas      # optional, must match ABLY_CHANNEL

# ══════════════════════════════════════════════════════════════════════════════
# MODE: database  (Supabase Realtime + Postgres – persistent)
# ══════════════════════════════════════════════════════════════════════════════
# 1. Create a free project at https://supabase.com
# 2. In the SQL editor, run the schema below
# 3. Copy the Project URL and keys from Settings → API

# Local watcher (service-role key – secret, never commit)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...
SUPABASE_WORKSPACE_ID=default         # optional row ID, default: "default"

# Frontend / Vercel build-time variables
VITE_APP_SYNC_MODE=database
VITE_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_APP_SUPABASE_ANON_KEY=eyJ...your-anon-key...   # safe to expose
VITE_APP_SUPABASE_WORKSPACE_ID=default

# ── Supabase schema ───────────────────────────────────────────────────────────
# Run this SQL in the Supabase dashboard → SQL Editor:
#
# create table if not exists workspaces (
#   id          text        primary key default 'default',
#   elements    jsonb       not null    default '[]'::jsonb,
#   app_state   jsonb       not null    default '{}'::jsonb,
#   updated_by  text        not null    default 'frontend',
#   updated_at  timestamptz not null    default now()
# );
#
# -- Allow the frontend (anon key) to read and write
# alter table workspaces enable row level security;
# create policy "allow all"
#   on workspaces for all
#   using (true)
#   with check (true);
#
# -- Enable Realtime for this table
# alter publication supabase_realtime add table workspaces;
